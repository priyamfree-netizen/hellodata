# BillSOS Mobile — runtime config (loaded via flutter_dotenv).
# PUBLIC values only. NEVER put SMTP_*, SERVICE_ROLE, or JWT secrets here — email is
# sent by the backend Worker (which holds the SMTP creds), not by the app.
#
# API_BASE_URL = the origin that serves the /api/* endpoints (your web app / Worker).
#   • Android emulator  -> host machine's localhost is reachable as 10.0.2.2
#                          (so local `vite dev` on :8080 => http://10.0.2.2:8080)
#   • iOS simulator     -> http://localhost:8080
#   • Physical device   -> your dev machine's LAN IP, e.g. http://192.168.1.5:8080
#   • Deployed backend  -> https://your-domain
API_BASE_URL=http://10.0.2.2:8080

# Supabase (self-hosted). These are safe to ship — anon key is a public client key.
SUPABASE_URL=https://monitor.dninfo.online
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjIwMDAwMDAwMDB9.k7v2qrqEWsNOg_KFhr6LKnbCacfHzxpYO0TkHYmANXw
