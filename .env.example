# =============================================================================
# BillSOS · Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (https://supabase.com/dashboard/project/_/settings/api).
#
# Vite exposes any variable prefixed with VITE_ to client-side bundles.
# Anything secret (service role key) MUST NOT use the VITE_ prefix.
# =============================================================================

# ── Supabase (client + server) ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ── Supabase (server-only, e.g. cron/edge functions) ─────────────────────────
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_PROJECT_JWT_SECRET
# JWT_SECRET is deprecated. A local random JWT_SECRET will be rejected by Supabase REST/RLS.
TOTP_ENCRYPTION_KEY=YOUR_64_HEX_CHARACTER_AES_KEY
EXDOC_API_BASE_URL=https://exdocapi.cheapehai.shop
EXDOC_API_KEY=YOUR_EXDOC_API_KEY

# ── SMTP email delivery (server-only) ───────────────────────────────────────
# Use 587 for STARTTLS, 465 for SSL, or 2525 if your provider supports it.
# Cloudflare Workers cannot send SMTP on port 25.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USERNAME
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM="BillSOS <noreply@yourdomain.com>"
SMTP_REPLY_TO=support@yourdomain.com
# auto = SSL on 465, otherwise STARTTLS. Set true/ssl or false/plain if needed.
SMTP_SECURE=auto

# ── App configuration ────────────────────────────────────────────────────────
VITE_APP_NAME=BillSOS
# Set this to your production app domain (NOT the Supabase server domain).
# This is used as the redirect target in confirmation emails and OAuth flows.
# Example: https://billsos.com  or  https://app.billsos.com
VITE_APP_URL=http://localhost:5173
